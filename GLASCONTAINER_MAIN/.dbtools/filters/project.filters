or object_name = 'FTTH_GLASCONTAINER_AKTIONEN'
or object_name = 'FTTH_GLASCONTAINER_PRODUKTE'
or object_name = 'FTTH_PREORDERS_FUZZYDOUBLE'
or object_name = 'FTTH_PRODUKTE_GK'
or object_name = 'FTTH_WEBSERVICE_AUFRUFE'
or object_name = 'FTTH_WS_SYNC_PREORDERS'
or object_name = 'FTTH_WS_SYNC_STORNOGRUENDE'
or object_name = 'GC_TASK_SEQ' -- SEQUENCE
or object_name = 'LOV_SIEBEL_ANSPRECHPARTNER' 
or object_name = 'PCK_ADRESSE' 
or object_name = 'PCK_FTTH_VALIDATE_EMAIL' 
or object_name = 'PCK_FUZZYDOUBLE' 
or object_name = 'PCK_GLASCONTAINER' 
or object_name = 'PCK_GLASCONTAINER_ADMIN' 
or object_name = 'PCK_GLASCONTAINER_DUBLETTEN' 
or object_name = 'PCK_GLASCONTAINER_EXT' 
or object_name = 'PCK_GLASCONTAINER_GK' 
